{
  "name": "casterly",
  "version": "1.0.0",
  "description": "Local-first privacy-aware LLM router",
  "main": "dist/src/index.js",
  "bin": {
    "casterly": "dist/src/index.js"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "vitest run",
    "install:host": "npm run build && node scripts/install-host.mjs",
    "guardrails": "node scripts/guardrails.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "check": "npm run guardrails && npm run lint && npm run typecheck && npm run test && npm run security:scan",
    "imessage": "tsx src/imessage-daemon.ts",
    "imessage:start": "npm run build && node dist/src/imessage-daemon.js",
    "test:e2e": "tsx src/test-cli.ts",
    "test:trace": "tsx src/test-cli.ts --trace",
    "test:interactive": "tsx src/test-cli.ts --interactive",
    "benchmark": "tsx src/benchmark-cli.ts run",
    "benchmark:compare": "tsx src/benchmark-cli.ts compare",
    "test:coverage": "vitest run --coverage",
    "repl": "tsx src/terminal-repl.ts",
    "inspect": "tsx src/debug/inspector.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "csv-parse": "^6.1.0",
    "exceljs": "^4.4.0",
    "extract-zip": "^2.0.1",
    "file-type": "^19.6.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "tar": "^7.5.7",
    "undici": "^7.22.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-security": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
