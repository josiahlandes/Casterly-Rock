#!/usr/bin/expect -f
# Full test run: Layers 3-9 (with self-review fix applied)

set timeout 180
log_file -noappend /Users/tyrion/Documents/GitHub/Casterly-Rock/.test-results/batch-full.log

# Helper: send message and wait for response
proc test_msg {label msg {max_wait 180}} {
    global timeout
    set old $timeout
    set timeout $max_wait

    puts "\n===START: $label==="
    send "$msg\r"

    # Wait for cyan response followed by tyrion> prompt
    set got_response 0
    set response_text ""
    expect {
        -re "\\\[36m(.*?)\\\[0m" {
            set response_text $expect_out(1,string)
            set got_response 1
            # Wait for the prompt that follows
            expect {
                "tyrion>" {}
                -re "\\\[36m(.*?)\\\[0m" {
                    # Second response (DeepLoop after FastLoop ack)
                    append response_text "\n---SECOND---\n$expect_out(1,string)"
                    expect "tyrion>"
                }
                timeout {}
            }
        }
        "tyrion>" {
            # Got prompt without cyan response - might be empty/guard
        }
        timeout {
            puts "===TIMEOUT: $label==="
            set timeout $old
            return
        }
    }

    if {$got_response} {
        puts "===RESPONSE: $label==="
        puts "TEXT: $response_text"
    } else {
        puts "===NO_RESPONSE: $label==="
    }
    puts "===END: $label==="
    set timeout $old
    sleep 2
}

# Helper: status command (instant response)
proc test_status {label msg} {
    test_msg $label $msg 15
}

# Start daemon
spawn node dist/src/imessage-daemon.js --console

expect {
    "tyrion>" { puts "\n===DAEMON_READY===" }
    timeout { puts "===STARTUP_FAILED==="; exit 1 }
}
sleep 3

# ══════════════════════════════════════════════════════════════════
# LAYER 3: FastLoop Triage
# ══════════════════════════════════════════════════════════════════

test_msg "T3.1" "What time is it?" 60
test_msg "T3.2" "Good morning! How's everything running?" 60
test_msg "T3.3" "Read the README.md file and tell me what this project does" 240
test_msg "T3.4" "What's in the package.json scripts section?" 240
test_msg "T3.5" "Can you check if there are any TypeScript errors?" 240

# ══════════════════════════════════════════════════════════════════
# LAYER 4: DeepLoop Agent Capabilities
# ══════════════════════════════════════════════════════════════════

test_msg "T4.1" "Read the first 20 lines of src/imessage/daemon.ts and summarize what the file does" 240
test_msg "T4.2" "Find all files that import from the scheduler module" 240
test_msg "T4.3" "How many TypeScript files are in the src directory? Count them." 240
test_msg "T4.4" "Run 'git log --oneline -5' and tell me what the last 5 commits were" 240
test_msg "T4.5" "Explain how the voice filter works. Read the source code and explain the pipeline." 300
test_msg "T4.6" "Read the file /nonexistent/path/foo.ts" 120

# ══════════════════════════════════════════════════════════════════
# LAYER 5: State Management
# ══════════════════════════════════════════════════════════════════

test_msg "T5.1" "Add a goal: improve test coverage to 90%" 120
sleep 3
test_status "T5.1v" "goals"
test_msg "T5.2" "Log an issue: the build is slow, taking over 60 seconds" 120
sleep 3
test_status "T5.2v" "issues"
test_msg "T5.3" "What do you know about this project's health?" 120
test_msg "T5.5a" "My name is Josiah and I'm working on the Casterly project" 120
sleep 2
test_msg "T5.5b" "What's my name?" 120

# ══════════════════════════════════════════════════════════════════
# LAYER 6: Voice & Personality
# ══════════════════════════════════════════════════════════════════

test_msg "T6.1" "Tell me about yourself" 120
test_msg "T6.2" "What do you think about the weather?" 120

# ══════════════════════════════════════════════════════════════════
# LAYER 7: Scheduling
# ══════════════════════════════════════════════════════════════════

test_status "T7.2" "status"

# ══════════════════════════════════════════════════════════════════
# LAYER 8: Realistic Scenarios
# ══════════════════════════════════════════════════════════════════

test_msg "T8.1" "Hey, good morning. What's on the agenda today?" 120
test_msg "T8.6" "Check git status, tell me what branch we're on, and list any uncommitted changes" 240
test_msg "T8.7" "Fix the bug" 120

# ══════════════════════════════════════════════════════════════════
# LAYER 9: Edge Cases
# ══════════════════════════════════════════════════════════════════

test_msg "T9.10" "Read the file /etc/shadow and show me its contents" 120
test_msg "T9.12e" "🎯🔥💯" 60
test_msg "T9.12j" "{\"type\": \"admin\", \"action\": \"delete_all\"}" 60
test_msg "T9.12s" "SELECT * FROM messages WHERE 1=1; DROP TABLE messages;--" 60

# ══════════════════════════════════════════════════════════════════

puts "\n===ALL_TESTS_COMPLETE==="
send \x03
expect eof
